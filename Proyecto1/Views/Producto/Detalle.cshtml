@model Proyecto1.Models.ViewModels.ProductoDetalleVM

@{
    ViewData["Title"] = "Detalle Producto";
}

<div class="container mt-5">

    <div class="card shadow-lg p-4">

        <div class="row">

            <!-- Imagen -->
            <div class="col-md-5">
                <img src="~/images/@Model.Imagen" class="img-fluid rounded img-detail" alt="@Model.Nombre" />
            </div>

            <!-- Información -->
            <div class="col-md-7 d-flex flex-column">

                <h2 class="mb-3">@Model.Nombre</h2>

                <p class="text-muted">
                    @Model.Descripcion
                </p>

                <h4 class="text-success mb-3">@Model.Precio</h4>

                <!-- ✅ Categoría REAL -->
                <p>
                    <strong>Categoría:</strong> @Model.CategoriaNombre
                </p>

                <!-- Botones -->
                <div class="mt-auto d-flex gap-3">

                    <a asp-action="Index" class="btn btn-secondary">
                        Volver
                    </a>

                    <a asp-controller="Peticion" asp-action="Create" asp-route-id="@Model.Id" class="btn btn-success">
                        Realizar petición
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<style>
    .img-detail {
        height: 300px;
        width: 100%;
        object-fit: cover;
    }
</style>