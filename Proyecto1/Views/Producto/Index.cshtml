@model IEnumerable<Proyecto1.Models.Producto>

@if (TempData["Success"] != null)
{
    <div id="alertSuccess" class="alert alert-success alert-dismissible fade show text-center fw-bold" role="alert">
        ✔ @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@{
    ViewData["Title"] = "Productos";
}

<div class="container mt-5">

    <h1 class="text-center mb-5">Nuestros Productos</h1>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow product-card">

                    <!-- Imagen -->
                    <img src="~/images/@item.Imagen" class="card-img-top img-product" alt="@item.Nombre" />

                    <!-- Contenido -->
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Nombre</h5>

                        <p class="card-text text-muted">
                            @item.Descripcion
                        </p>

                        <p class="fw-bold">@item.Precio</p>

                        <!-- Botones -->
                        <div class="mt-auto d-flex justify-content-between">
                            <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-primary">
                                Ver Detalles
                            </a>

                            <a asp-controller="Peticion" asp-action="Create" asp-route-id="@item.Id" class="btn btn-success">
                                Realizar petición
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        }

    </div>

</div>

<style>
    .img-product {
        height: 220px;
        object-fit: cover;
    }

    .product-card {
        border-radius: 12px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }
</style>
<script>
    setTimeout(() => {
        let alert = document.getElementById("alertSuccess");
        if (alert) {
            alert.classList.remove("show"); // animación bootstrap
            alert.classList.add("fade");

            setTimeout(() => {
                alert.remove(); // lo elimina del DOM
            }, 500);
        }
    }, 3000); // ⏱️ 3 segundos
</script>